# ==========================================
# 1. 核心安全与隐私（绝对不能泄露的 Key 和密码）
# ==========================================
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
config/local_config.json
.ipynb_checkpoints/

# ==========================================
# 2. Python 运行环境与缓存（避免污染仓库）
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.htmlcov/
htmlcov/

# ==========================================
# 3. 虚拟环境（体积巨大，别人不需要你的本地环境）
# ==========================================
venv/
.venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ==========================================
# 4. 操作系统与编辑器缓存（个人习惯文件）
# ==========================================
.DS_Store
.DS_Store?
ehthumbs.db
Icon?
Thumbs.db
.idea/               # 如果你用 PyCharm，忽略这个
.vscode/             # 如果你用 VS Code，忽略这个
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==========================================
# 5. AI/大模型/深度学习特有（大文件与本地日志）
# ==========================================
*.log
logs/
data/                # 本地测试用的数据集文件夹
models/              # 本地下载的模型权重（动辄几个G，千万别推）
.ipynb_checkpoints/  # Jupyter Notebook 自动生成的缓存
